# VoltLabs Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/voltlabs

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# Google Play reviewer test account (fixed OTP, no SMS sent, never expires)
REVIEW_TEST_PHONE=+911234567890
REVIEW_TEST_OTP=482917
